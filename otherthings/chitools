	printf "  ${CYN}fix${RST} audio                  restart pipewire + fix T460 HDA driver\n"
}

cmd="${1:-}"
[ -n "$cmd" ] && shift

case "$cmd" in
status)      cmd_status ;;
build)       cmd_build "$@" ;;
font)        cmd_font "$@" ;;
wifi)        cmd_wifi "$@" ;;
eth)         cmd_eth "$@" ;;
service)     cmd_service "$@" ;;
pkg)         cmd_pkg "$@" ;;
wallpaper)   cmd_wallpaper "$@" ;;
audio)       cmd_audio "$@" ;;
update)      cmd_update ;;
fix)         cmd_fix "$@" ;;
help|--help|-h|"") usage ;;
*)           die "unknown command: $cmd (run 'chitools help')" ;;
esac
