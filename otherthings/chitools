cmd_status() {
	hdr "ThiccPad status"
	printf "  uptime:  "; awk '{printf "%d min\n", $1/60}' /proc/uptime
	printf "  load:    "; awk '{print $1, $2, $3}' /proc/loadavg
	printf "  mem:     "; awk '/MemAvailable/{a=$2} /MemTotal/{t=$2} END{printf "%d MB free / %d MB total\n", a/1024, t/1024}' /proc/meminfo
	printf "  disk:    "; df -h / | awk 'NR==2{print $4" free of "$2}'
	printf "  bat:     "
	total=0; count=0; charging=""
	for b in BAT0 BAT1; do
		[ -d "/sys/class/power_supply/$b" ] || continue
		cap=$(cat /sys/class/power_supply/$b/capacity 2>/dev/null)
		status=$(cat /sys/class/power_supply/$b/status 2>/dev/null)
		[ -z "$cap" ] && continue
		total=$((total + cap)); count=$((count + 1))
		[ "$status" = "Charging" ] && charging="+"
	done
	[ "$count" -gt 0 ] && printf "%d%%%s\n" $((total / count)) "$charging" || printf "n/a\n"

	printf "  wifi:    "
	for iface in wlp3s0 wlan0 wlp2s0 wlp4s0; do
		[ -d "/sys/class/net/$iface" ] || continue
		ssid=$(iw dev "$iface" link 2>/dev/null | awk '/SSID:/{print $2}')
		[ -n "$ssid" ] && printf "%s (%s)\n" "$ssid" "$iface" || printf "disconnected (%s)\n" "$iface"
		break
	done
}

cmd_patch_interp() {
	die "patch-interp: not applicable on Artix (glibc) — only needed for musl systems"
}

cmd_font() {
	action="${1:-list}"
	case "$action" in
	list)
		hdr "Installed fonts"
		fc-list | sort
		;;
	cache)
		hdr "Rebuilding font cache..."
		fc-cache -fv && ok "done"
		;;
	install)
		url="${2:-}"
		[ -z "$url" ] && die "usage: chitools font install <url.zip>"
		hdr "Installing font from $url..."
		mkdir -p ~/.local/share/fonts
		cd ~/.local/share/fonts
		curl -OL "$url"
		unzip -o "$(basename "$url")"
		fc-cache -fv && ok "font installed"
		;;
	*)
		die "font: unknown action (list|cache|install <url>)"
		;;
	esac
}

cmd_wifi() {
	action="${1:-list}"; shift 2>/dev/null
	case "$action" in
	list)
		hdr "Available networks"
		nmcli -f SSID,BARS,SECURITY device wifi list
		;;
	connect)
		ssid="${1:-}"; [ -z "$ssid" ] && die "usage: chitools wifi connect <ssid> [password]"
		pass="${2:-}"
		if [ -n "$pass" ]; then
			nmcli device wifi connect "$ssid" password "$pass" && ok "connected to $ssid"
		else
			nmcli device wifi connect "$ssid" && ok "connected to $ssid"
		fi
		;;
	disconnect)
		nmcli device disconnect wlp3s0 2>/dev/null \
			|| nmcli device disconnect wlan0 2>/dev/null \
			&& ok "disconnected"
		;;
	status)
		nmcli device status
		;;
	on)  nmcli radio wifi on  && ok "wifi on" ;;
	off) nmcli radio wifi off && ok "wifi off" ;;
	*)   die "wifi: unknown action (list|connect|disconnect|status|on|off)" ;;
	esac
}

cmd_eth() {
	action="${1:-status}"
	case "$action" in
	status)
		hdr "Ethernet status"
		for iface in eth0 enp0s25 enp1s0 eno1; do
			[ -d "/sys/class/net/$iface" ] || continue
			state=$(cat /sys/class/net/$iface/operstate 2>/dev/null)
			printf "  %s: %s\n" "$iface" "$state"
		done
		nmcli device status | grep ethernet
		;;
	connect)
		nmcli device connect enp0s25 2>/dev/null \
			|| nmcli device connect eth0 2>/dev/null \
			&& ok "ethernet connected"
		;;
	disconnect)
		nmcli device disconnect enp0s25 2>/dev/null \
			|| nmcli device disconnect eth0 2>/dev/null \
			&& ok "ethernet disconnected"
		;;
	*)   die "eth: unknown action (status|connect|disconnect)" ;;
	esac
}

cmd_service() {
	action="${1:-}"; name="${2:-}"
	[ -z "$action" ] || [ -z "$name" ] && die "usage: chitools service <start|stop|status> <name>"
	case "$action" in
	start)  need_root; dinitctl start "$name"  && ok "started $name" ;;
	stop)   need_root; dinitctl stop "$name"   && ok "stopped $name" ;;
	status) dinitctl status "$name" ;;
	*)      die "service: unknown action (start|stop|status)" ;;
	esac
}

cmd_wallpaper() {
	action="${1:-set}"
	case "$action" in
	set)
		file="${2:-}"
		[ -z "$file" ] && die "usage: chitools wallpaper set <file>"
		[ -f "$file" ] || die "file not found: $file"
		ext="${file##*.}"
		cp "$file" ~/.wallpaper
		case "$ext" in
		gif|GIF) chiwallpaper -g ~/.wallpaper & ok "wallpaper set (animated)" ;;
		*)       chiwallpaper ~/.wallpaper    && ok "wallpaper set" ;;
		esac
		;;
	apply)
		[ -f ~/.wallpaper ] || die "no wallpaper saved — run: chitools wallpaper set <file>"
		chiwallpaper ~/.wallpaper && ok "wallpaper applied"
		;;
	clear)
		rm -f ~/.wallpaper && xsetroot -solid "#1e1224" && ok "wallpaper cleared"
		;;
	*)
		die "wallpaper: unknown action (set <file>|apply|clear)"
		;;
	esac
}

cmd_audio() {
	action="${1:-list}"; [ -n "${1:-}" ] && shift
	export XDG_RUNTIME_DIR="${XDG_RUNTIME_DIR:-/run/user/$(id -u)}"
	case "$action" in
	list)
		hdr "Audio sinks"
		wpctl status | awk '/Sinks:/{f=1;next} f&&/Sources:/{exit} f&&/[0-9]+\./{print}'
		;;
	set)
		id="${1:-}"; [ -z "$id" ] && die "usage: chitools audio set <sink-id>"
		wpctl set-default "$id" && ok "default sink → $id"
		;;
	status)
		hdr "Current default sink"
		wpctl status | awk '/Sinks:/{f=1;next} f&&/Sources:/{exit} f&&/\*/{print;exit}'
		;;
	*)
		die "audio: unknown action (list|set <id>|status)"
		;;
	esac
}

cmd_update() {
	hdr "Updating system packages..."
	need_root
	pacman -Syu --noconfirm || die "pacman upgrade failed"
	ok "system updated"

	hdr "Applying hardware fixes..."
	# T460 Skylake: SOF driver takes priority but fails; force legacy HDA
	echo "options snd_intel_dspcfg dsp_driver=1" > /etc/modprobe.d/snd-hda.conf
	ok "audio: T460 HDA driver pinned"
}

cmd_fix() {
	action="${1:-}"; [ -n "${1:-}" ] && shift
	case "$action" in
	audio)
		hdr "Fixing audio..."
		need_root
		# Ensure HDA driver is forced (T460 Skylake SOF conflict)
		echo "options snd_intel_dspcfg dsp_driver=1" > /etc/modprobe.d/snd-hda.conf
		ok "modprobe config written"

		# Restart pipewire stack as the user (not root)
		hdr "Restarting pipewire..."
		printf '#!/bin/sh\npkill wireplumber; pkill pipewire-pulse; pkill pipewire; sleep 1\nXDG_RUNTIME_DIR="/run/user/$(id -u)"\npipewire >/dev/null 2>&1 &\nsleep 0.5; pipewire-pulse >/dev/null 2>&1 &\nsleep 0.5; wireplumber >/dev/null 2>&1 &\nsleep 2; wpctl status\n' > /tmp/chi-fix-audio.sh
		chmod +x /tmp/chi-fix-audio.sh
		su mark -c '/tmp/chi-fix-audio.sh' 2>/dev/null | grep -A6 "Sinks:"
		ok "pipewire restarted — check sinks above"
		printf "${YEL}note:${RST} if still dummy output, reboot to reload kernel modules\n"
		;;
	*)
		die "fix: unknown target (audio)"
		;;
	esac
}

cmd_pkg() {
	action="${1:-}"; shift
	[ -z "$action" ] && die "usage: chitools pkg <search|install|remove|upgrade> [name]"
	case "$action" in
	search)  pacman -Ss "$@" ;;
	install) need_root; pacman -S --noconfirm "$@" && ok "installed: $*" ;;
	remove)  need_root; pacman -Rns --noconfirm "$@" && ok "removed: $*" ;;
	upgrade) need_root; pacman -Syu --noconfirm && ok "system upgraded" ;;
	*)       die "pkg: unknown action (search|install|remove|upgrade)" ;;
	esac
}

