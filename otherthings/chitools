	printf "  ${CYN}font${RST} list                  list installed fonts\n"
	printf "  ${CYN}font${RST} cache                 rebuild fc-cache\n"
	printf "  ${CYN}font${RST} install <url.zip>     download and install a font zip\n"
	printf "  ${CYN}wifi${RST} list                  scan for networks\n"
	printf "  ${CYN}wifi${RST} connect <ssid> [pass]  connect to network\n"
