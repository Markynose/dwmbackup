#!/bin/sh
# chitools — Artix Linux (dinit) / ThiccPad local management CLI

DWM_SRC="/home/mark/dwm-src"
ST_SRC="/home/mark/st"
DMENU_SRC="/home/mark/dmenu"
SXWM_SRC="/home/mark/sxwm"
DWM_CFG="/home/mark/dwm"

RED='\033[1;31m'
YEL='\033[1;33m'
PNK='\033[1;35m'
CYN='\033[1;36m'
GRN='\033[1;32m'
RST='\033[0m'

die() { printf "${RED}error:${RST} %s\n" "$*" >&2; exit 1; }
ok()  { printf "${GRN}ok:${RST} %s\n" "$*"; }
hdr() { printf "${PNK}==> %s${RST}\n" "$*"; }

IS_ROOT=0
[ "$(id -u)" -eq 0 ] && IS_ROOT=1

if [ "$IS_ROOT" -eq 1 ]; then
	printf "${RED}Root detected. Be careful. Ok?${RST}\n\n"
fi

need_root() {
	[ "$IS_ROOT" -eq 1 ] || die "no root, no install — run with: doas chitools $cmd $*"
}

# --- commands ---

pkill_bin() { pkill "$1" 2>/dev/null || true; }

