#!/bin/sh
# chiharden — sysctl hardening toggle for Chimera Linux

RUNDIR=/var/lib/chiharden
ORIG="$RUNDIR/sysctl.orig"
STATE="$RUNDIR/state"

die()  { printf '\033[1;31merror:\033[0m %s\n' "$*" >&2; exit 1; }
ok()   { printf '\033[1;32mok:\033[0m %s\n' "$*"; }
hdr()  { printf '\033[1;35m==> %s\033[0m\n' "$*"; }
warn() { printf '\033[1;33mwarn:\033[0m %s\n' "$*"; }

# all keys we may touch — saved before hardening for restore
KEYS="
kernel.dmesg_restrict
kernel.kptr_restrict
kernel.yama.ptrace_scope
kernel.perf_event_paranoid
kernel.unprivileged_bpf_disabled
kernel.sysrq
kernel.kexec_load_disabled
kernel.randomize_va_space
net.core.bpf_jit_harden
fs.suid_dumpable
fs.protected_hardlinks
fs.protected_symlinks
net.ipv4.conf.all.rp_filter
net.ipv4.conf.default.rp_filter
net.ipv4.conf.all.accept_redirects
net.ipv4.conf.default.accept_redirects
net.ipv4.conf.all.send_redirects
net.ipv4.conf.default.send_redirects
net.ipv4.conf.all.accept_source_route
net.ipv4.conf.all.log_martians
net.ipv4.conf.default.log_martians
net.ipv4.tcp_syncookies
net.ipv6.conf.all.accept_redirects
net.ipv6.conf.all.disable_ipv6
net.ipv6.conf.default.disable_ipv6
net.ipv4.icmp_echo_ignore_broadcasts
net.ipv4.tcp_timestamps
net.ipv4.conf.all.secure_redirects
kernel.panic_on_oops
vm.mmap_rnd_bits
"

# level 1: network hardening + info leak prevention
L1="
kernel.dmesg_restrict=1
kernel.kptr_restrict=2
fs.suid_dumpable=0
net.ipv4.conf.all.rp_filter=1
net.ipv4.conf.default.rp_filter=1
net.ipv4.conf.all.accept_redirects=0
net.ipv4.conf.default.accept_redirects=0
net.ipv4.conf.all.send_redirects=0
net.ipv4.conf.default.send_redirects=0
net.ipv4.conf.all.accept_source_route=0
net.ipv6.conf.all.accept_redirects=0
net.ipv4.icmp_echo_ignore_broadcasts=1
"

# level 2: adds local privilege escalation hardening
L2="$L1
kernel.yama.ptrace_scope=2
kernel.perf_event_paranoid=3
kernel.unprivileged_bpf_disabled=1
kernel.sysrq=0
net.core.bpf_jit_harden=2
fs.protected_hardlinks=1
fs.protected_symlinks=1
"

# level 3: paranoid — kexec disabled, module loading locked (modules_disabled is ONE-WAY until reboot)
L3="$L2
kernel.kexec_load_disabled=1
kernel.modules_disabled=1
"

# level 4: max — full ASLR, SYN cookies, log martians, IPv6 disabled
L4="$L3
kernel.randomize_va_space=2
vm.mmap_rnd_bits=32
net.ipv4.tcp_syncookies=1
net.ipv4.conf.all.log_martians=1
net.ipv4.conf.default.log_martians=1
net.ipv6.conf.all.disable_ipv6=1
net.ipv6.conf.default.disable_ipv6=1
"

# level 5: full paranoid — session-only, reverts to level 2 on reboot
# panic_on_oops stops exploit continuation after kernel oops
L5="$L4
kernel.panic_on_oops=1
net.ipv4.tcp_timestamps=0
net.ipv4.conf.all.secure_redirects=1
net.ipv4.conf.default.secure_redirects=1
"

save_orig() {
	mkdir -p "$RUNDIR"
	rm -f "$ORIG"
	for k in $KEYS; do
		v=$(sysctl -n "$k" 2>/dev/null) || continue
		printf '%s=%s\n' "$k" "$v" >> "$ORIG"
	done
}

apply_values() {
	_apply="$1"
	_persist="${2:-$1}"
	printf '%s\n' "$_persist" | grep -v '^[[:space:]]*$' > /etc/sysctl.d/99-chiharden.conf
	for kv in $_apply; do
		sysctl -w "$kv" >/dev/null 2>&1 || printf '  skip (unavailable): %s\n' "$kv"
	done
}

restore_orig() {
	[ -f "$ORIG" ] || die "no saved state — was harden run?"
	rm -f /etc/sysctl.d/99-chiharden.conf
	while IFS='=' read -r k v; do
		[ -z "$k" ] && continue
		sysctl -w "$k=$v" >/dev/null 2>&1 || printf '  skip (unavailable): %s\n' "$k"
	done < "$ORIG"
}

harden() {
	[ "$(id -u)" -eq 0 ] || die "must run as root (doas chiharden harden [1-3])"
	cur=$(cat "$STATE" 2>/dev/null)
	case "$cur" in hardened-*) die "already hardened (${cur#hardened-}) — unharden first" ;; esac

	level="${1:-2}"
	case "$level" in
		1) values="$L1" ;;
		2) values="$L2" ;;
		3) values="$L3"
		   warn "level 3: kernel.modules_disabled is ONE-WAY — no module loads until reboot"
		   printf 'continue? [y/N] '
		   read -r ans
		   [ "$ans" = y ] || [ "$ans" = Y ] || { printf 'aborted.\n'; exit 0; }
		   ;;
		4) values="$L4"
		   warn "level 4: modules_disabled ONE-WAY + IPv6 will be disabled"
		   warn "on reboot this machine will come back at level 2 (not level 4)"
		   printf 'continue? [y/N] '
		   read -r ans
		   [ "$ans" = y ] || [ "$ans" = Y ] || { printf 'aborted.\n'; exit 0; }
		   ;;
		5) values="$L5"
		   warn "level 5: full paranoid — panic_on_oops, no TCP timestamps, session-only"
		   warn "on reboot this machine will come back at level 2 (not level 5)"
		   printf 'are you sure? this will panic the kernel on any oops [yes/N] '
		   read -r ans
		   [ "$ans" = yes ] || { printf 'aborted.\n'; exit 0; }
		   ;;
		*) die "invalid level: $level (valid: 1 2 3 4 5)" ;;
	esac

	hdr "Saving current sysctl state..."
	save_orig
	hdr "Applying level $level hardening..."
	case "$level" in
		4|5) apply_values "$values" "$L2" ;;
		*)   apply_values "$values" ;;
	esac
	printf 'hardened-%s\n' "$level" > "$STATE"
	ok "system hardened (level $level)"
}

unharden() {
	[ "$(id -u)" -eq 0 ] || die "must run as root (doas chiharden unharden)"
	cur=$(cat "$STATE" 2>/dev/null)
	[ -z "$cur" ] && die "not hardened"
	[ "$cur" = unhardened ] && die "already unhardened"
	case "$cur" in
		hardened-3|hardened-4|hardened-5) warn "kernel.modules_disabled cannot be unset — requires reboot to take effect" ;;
	esac
	hdr "Restoring original sysctl..."
	restore_orig
	echo unhardened > "$STATE"
	ok "system unhardened"
}

key_desc() {
	case "$1" in
		kernel.dmesg_restrict)             printf 'restrict dmesg to root' ;;
		kernel.kptr_restrict)              printf 'hide kernel pointers in /proc (*)' ;;
		kernel.yama.ptrace_scope)          printf 'ptrace access scope (*)' ;;
		kernel.perf_event_paranoid)        printf 'perf subsystem access (*)' ;;
		kernel.unprivileged_bpf_disabled)  printf 'block unprivileged eBPF' ;;
		kernel.sysrq)                      printf 'magic sysrq keys (*)' ;;
		kernel.kexec_load_disabled)        printf 'block kexec kernel replacement' ;;
		kernel.randomize_va_space)         printf 'ASLR (*)' ;;
		net.core.bpf_jit_harden)           printf 'BPF JIT hardening (*)' ;;
		fs.suid_dumpable)                  printf 'core dumps for setuid procs (*)' ;;
		fs.protected_hardlinks)            printf 'block hardlink attacks in sticky dirs' ;;
		fs.protected_symlinks)             printf 'block symlink TOCTOU in sticky dirs' ;;
		net.ipv4.conf.all.rp_filter)       printf 'reverse path filter, blocks IP spoofing' ;;
		net.ipv4.conf.all.accept_redirects) printf 'accept ICMP redirects (MITM risk)' ;;
		net.ipv4.conf.all.send_redirects)  printf 'advertise routes to others' ;;
		net.ipv4.conf.all.accept_source_route) printf 'accept attacker-controlled routing' ;;
		net.ipv4.conf.all.log_martians)    printf 'log spoofed/bogus packets' ;;
		net.ipv4.tcp_syncookies)           printf 'SYN flood protection' ;;
		net.ipv6.conf.all.disable_ipv6)    printf 'disable IPv6 entirely' ;;
		net.ipv4.tcp_timestamps)           printf 'TCP timestamps (uptime fingerprint)' ;;
		net.ipv4.conf.all.secure_redirects) printf 'only accept redirects from known gateways' ;;
		kernel.panic_on_oops)              printf 'panic instead of continue after kernel oops' ;;
		vm.mmap_rnd_bits)                  printf 'ASLR mmap entropy bits' ;;
		*) printf '' ;;
	esac
}

status() {
	cur=$(cat "$STATE" 2>/dev/null)
	case "$cur" in
		hardened-*)
			level="${cur#hardened-}"
			printf 'state:    \033[1;32m%s\033[0m\n' "$cur"
			case "$level" in
				1) vals="$L1" ;;
				2) vals="$L2" ;;
				3) vals="$L3" ;;
				4) vals="$L4" ;;
				5) vals="$L5" ;;
			esac
			;;
		unhardened)
			printf 'state:    \033[1;33munhardened\033[0m\n'
			vals="" ;;
		*)
			printf 'state:    \033[1;33munknown\033[0m (harden not yet run)\n'
			vals="" ;;
	esac

	if [ -f /etc/sysctl.d/99-chiharden.conf ]; then
		printf 'persist:  \033[1;32myes\033[0m (/etc/sysctl.d/99-chiharden.conf)\n'
	else
		printf 'persist:  \033[1;31mno\033[0m\n'
	fi

	printf 'levels:   1=network/info-leaks  2=+local-privesc  3=+paranoid  4=max(session-only)  5=full-paranoid(session-only)\n'

	mod_count=$(ls /sys/module | wc -l 2>/dev/null)
	printf 'modules:  %s loaded\n' "$mod_count"

	printf '\n'
	printf '%-42s %-6s %-6s %s\n' "key" "cur" "tgt" "description"
	printf '%-42s %-6s %-6s %s\n' "---" "---" "---" "-----------"

	for k in \
		kernel.dmesg_restrict kernel.kptr_restrict kernel.yama.ptrace_scope \
		kernel.perf_event_paranoid kernel.unprivileged_bpf_disabled kernel.sysrq \
		kernel.kexec_load_disabled kernel.randomize_va_space net.core.bpf_jit_harden \
		fs.suid_dumpable fs.protected_hardlinks fs.protected_symlinks \
		net.ipv4.conf.all.rp_filter net.ipv4.conf.all.accept_redirects \
		net.ipv4.conf.all.send_redirects net.ipv4.conf.all.accept_source_route \
		net.ipv4.conf.all.log_martians net.ipv4.tcp_syncookies \
		net.ipv6.conf.all.disable_ipv6 net.ipv4.tcp_timestamps \
		net.ipv4.conf.all.secure_redirects kernel.panic_on_oops vm.mmap_rnd_bits; do
		v=$(sysctl -n "$k" 2>/dev/null) || continue
		target=$(printf '%s\n' "$vals" | grep "^${k}=" | cut -d= -f2-)
		desc=$(key_desc "$k")
		cur_pad=$(printf '%-6s' "$v")
		if [ -z "$target" ]; then
			printf '%-42s %-6s %-6s %s\n' "$k" "$v" "-" "$desc"
		elif [ "$v" = "$target" ]; then
			printf '%-42s \033[1;32m%s\033[0m %-6s %s\n' "$k" "$cur_pad" "$target" "$desc"
		else
			printf '%-42s \033[1;31m%s\033[0m %-6s %s\n' "$k" "$cur_pad" "$target" "$desc"
		fi
	done

	printf '\nlegend (*)\n'
	printf '  kptr_restrict:       0=exposed  1=hashed  2=hidden\n'
	printf '  ptrace_scope:        0=unrestricted  1=parent-only  2=admin-only\n'
	printf '  perf_event_paranoid: 1=no-raw-access  2=no-cpu-events  3=disabled\n'
	printf '  bpf_jit_harden:      0=none  1=unprivileged-only  2=all\n'
	printf '  sysrq:               0=disabled  1=all-enabled  4=sync/remount-only\n'
	printf '  suid_dumpable:       0=no-dumps  1=enabled  2=root-readable\n'
	printf '  randomize_va_space:  0=disabled  1=partial  2=full\n'
}

case "${1:-}" in
	harden)   harden "${2:-}" ;;
	unharden) unharden ;;
	status)   status ;;
	*) printf 'usage: chiharden harden [1-3]|unharden|status\n' >&2; exit 1 ;;
esac
